                      "name": "customer_segment",
                      "expression": "`customer_segment`"
                    },
                    {
                      "name": "avg_upsell_score",
                      "expression": "`avg_upsell_score`"
                    },
                    {
                      "name": "high_upsell_opportunities",
                      "expression": "`high_upsell_opportunities`"
                    }
                  ],
                  "disaggregated": false
