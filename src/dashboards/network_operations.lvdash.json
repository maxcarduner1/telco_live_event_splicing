  ],
  "datasets": [
    {
      "name": "ds_tower_summary",
      "displayName": "Tower Summary",
      "query": "SELECT COUNT(DISTINCT tower_id) AS active_towers, SUM(CASE WHEN congestion_predicted_15min = 1 THEN 1 ELSE 0 END) AS congested_towers, ROUND(MAX(peak_bandwidth_util), 1) AS peak_bandwidth_pct FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_congestion_features WHERE window_start >= current_timestamp() - INTERVAL 30 MINUTES"
    },
    {
      "name": "ds_slice_summary",
      "displayName": "Slice Summary",
      "query": "SELECT COUNT(*) AS active_slices, ROUND(SUM(revenue_per_hour), 2) AS revenue_per_hour FROM cmegdemos_catalog.dynamic_slicing_live_event.bronze_network_slices WHERE status = 'active'"
    },
    {
      "name": "ds_lumen_bandwidth_timeline",
      "displayName": "Lumen Field Bandwidth Timeline",
      "query": "SELECT tower_id, window_start, ROUND(avg_bandwidth_util, 2) AS avg_bandwidth_util, congestion_predicted_15min FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_congestion_features WHERE tower_id LIKE 'SEA-LF-%' ORDER BY window_start, tower_id"
    },
    {
      "name": "ds_latest_congestion",
      "displayName": "Latest Congestion Scores",
      "query": "SELECT tower_id, ROUND(avg_congestion_score, 2) AS avg_congestion_score, ROUND(avg_bandwidth_util, 2) AS avg_bandwidth_util, congestion_predicted_15min FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_congestion_features WHERE window_start = (SELECT MAX(window_start) FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_congestion_features) ORDER BY avg_congestion_score DESC"
    },
    {
      "name": "ds_event_revenue",
      "displayName": "Event Revenue Summary",
      "query": "SELECT event_name, customers_targeted, customers_converted, ROUND(conversion_rate * 100, 1) AS conversion_rate, ROUND(immediate_revenue_usd, 0) AS immediate_revenue_usd, ROUND(projected_arr_usd, 0) AS projected_arr_usd, sla_violations, customer_sat_improvement_pct FROM cmegdemos_catalog.dynamic_slicing_live_event.event_revenue_summary WHERE event_name = 'USMNT vs Australia' LIMIT 1"
    },
    {
      "name": "ds_revenue_by_segment",
      "displayName": "Revenue by Segment",
      "query": "SELECT customer_segment, SUM(projected_annual_revenue) AS projected_annual_revenue, SUM(projected_conversions) AS projected_conversions FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_revenue_analytics GROUP BY customer_segment ORDER BY projected_annual_revenue DESC"
    },
    {
      "name": "ds_conversion_scores",
      "displayName": "Conversion Scores by Segment",
      "query": "SELECT customer_segment, ROUND(AVG(avg_conversion_score), 4) AS avg_conversion_score, SUM(high_conversion_opportunities) AS high_conversion_opportunities, SUM(total_opportunities) AS total_opportunities FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_revenue_analytics GROUP BY customer_segment"
    },
    {
      "name": "ds_top_opportunities",
      "displayName": "Top Conversion Opportunities",
      "query": "SELECT customer_segment, ROUND(conversion_score, 3) AS conversion_score, monthly_revenue_opportunity, social_influence_score, tower_id FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_conversion_opportunities WHERE conversion_score >= 0.7 AND customer_segment IN ('high_value_influencer', 'influencer', 'high_value') ORDER BY social_influence_score DESC, conversion_score DESC LIMIT 100"
    }
  ]
}
