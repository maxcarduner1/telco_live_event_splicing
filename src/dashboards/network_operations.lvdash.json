            "x": 3,
            "y": 0,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi_proposals_accepted",
            "title": "B2B Accounts Accepted Upsell",
            "queries": [
              {
                "name": "main_query",
                "query": {
