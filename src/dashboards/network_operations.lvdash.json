        },
        {
          "widget": {
            "name": "kpi_burst_slices",
            "title": "Burst Slices Active",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_slice_summary",
                  "fields": [
                    {
                      "name": "burst_slices",
                      "expression": "`burst_slices`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "burst_slices",
                  "displayName": "Burst Slices Active"
                }
              }
            }
          },
          "position": {
            "x": 6,
            "y": 0,
            "width": 2,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "chart_bandwidth_over_time",
            "title": "Bandwidth Utilization Over Time — Lumen Field Towers (USMNT Match)",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_lumen_bandwidth_timeline",
                  "fields": [
                    {
                      "name": "window_start",
                      "expression": "`window_start`"
                    },
                    {
                      "name": "avg_bandwidth_util",
                      "expression": "`avg_bandwidth_util`"
                    },
                    {
                      "name": "tower_id",
                      "expression": "`tower_id`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "line",
              "encodings": {
                "x": {
                  "fieldName": "window_start",
                  "scale": {"type": "temporal"},
                  "displayName": "Time"
                },
                "y": {
                  "fieldName": "avg_bandwidth_util",
                  "scale": {"type": "quantitative"},
                  "displayName": "Avg Bandwidth Utilization (%)"
                },
                "color": {
                  "fieldName": "tower_id",
                  "scale": {"type": "categorical"},
                  "displayName": "Tower"
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 3,
            "width": 6,
            "height": 6
          }
        },
        {
          "widget": {
            "name": "chart_congestion_heatmap",
            "title": "Congestion Score by Tower — Latest Window",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_latest_congestion",
                  "fields": [
                    {
                      "name": "tower_id",
                      "expression": "`tower_id`"
                    },
                    {
                      "name": "avg_congestion_score",
                      "expression": "`avg_congestion_score`"
                    },
                    {
                      "name": "congestion_predicted_15min",
                      "expression": "`congestion_predicted_15min`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "tower_id",
                  "scale": {"type": "categorical"},
                  "displayName": "Tower ID"
                },
                "y": {
                  "fieldName": "avg_congestion_score",
                  "scale": {"type": "quantitative"},
                  "displayName": "Congestion Score"
                },
                "color": {
                  "fieldName": "congestion_predicted_15min",
                  "scale": {"type": "categorical"},
                  "displayName": "Congestion Predicted"
                }
              }
            }
          },
          "position": {
            "x": 6,
            "y": 3,
            "width": 6,
            "height": 6
          }
        }
      ]
    },
    {
