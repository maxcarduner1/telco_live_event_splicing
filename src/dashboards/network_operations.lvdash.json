{
  "pages": [
    {
      "name": "tower_health",
      "displayName": "Tower Health & Congestion",
      "layout": [
        {
          "widget": {
            "name": "kpi_total_towers",
            "title": "Active Towers",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_tower_summary",
                  "fields": [
                    {
                      "name": "active_towers",
                      "expression": "`active_towers`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "active_towers",
                  "displayName": "Active Towers"
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 2,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi_congested_towers",
            "title": "Towers in Congestion",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_tower_summary",
                  "fields": [
                    {
                      "name": "congested_towers",
                      "expression": "`congested_towers`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "congested_towers",
                  "displayName": "Congested Towers"
                }
              }
            }
          },
          "position": {
            "x": 2,
            "y": 0,
            "width": 2,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi_peak_bandwidth",
            "title": "Peak Bandwidth Utilization",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_tower_summary",
                  "fields": [
                    {
                      "name": "peak_bandwidth_pct",
                      "expression": "`peak_bandwidth_pct`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "peak_bandwidth_pct",
                  "displayName": "Peak Bandwidth %"
                }
              }
            }
          },
          "position": {
            "x": 4,
            "y": 0,
