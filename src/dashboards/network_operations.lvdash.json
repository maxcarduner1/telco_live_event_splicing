        },
        {
          "widget": {
            "name": "table_top_upsell_accounts",
            "title": "Top B2B Upsell Opportunities — Bandwidth Breach Risk",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_top_opportunities",
                  "fields": [
                    {"name": "company_name", "expression": "`company_name`"},
                    {"name": "customer_type", "expression": "`customer_type`"},
                    {"name": "utilization_pct", "expression": "`utilization_pct`"},
                    {"name": "breach_risk_level", "expression": "`breach_risk_level`"},
                    {"name": "conversion_score", "expression": "`conversion_score`"},
                    {"name": "monthly_revenue_opportunity", "expression": "`monthly_revenue_opportunity`"},
                    {"name": "tower_id", "expression": "`tower_id`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {"fieldName": "company_name", "displayName": "Company"},
                  {"fieldName": "customer_type", "displayName": "Type"},
                  {"fieldName": "utilization_pct", "displayName": "BW Util %"},
                  {"fieldName": "breach_risk_level", "displayName": "Breach Risk"},
                  {"fieldName": "conversion_score", "displayName": "Upsell Score"},
                  {"fieldName": "monthly_revenue_opportunity", "displayName": "MRR Opp ($)"},
                  {"fieldName": "tower_id", "displayName": "Tower"}
                ]
              }
            }
          },
          "position": {
            "x": 0,
            "y": 9,
            "width": 12,
            "height": 5
          }
        }
      ]
    }
  ],
  "datasets": [
    {
      "name": "ds_tower_summary",
      "displayName": "Tower Summary",
      "query": "SELECT COUNT(DISTINCT tower_id) AS active_towers, SUM(CASE WHEN congestion_predicted_15min = 1 THEN 1 ELSE 0 END) AS congested_towers, ROUND(MAX(peak_bandwidth_util), 1) AS peak_bandwidth_pct FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_congestion_features WHERE window_start >= current_timestamp() - INTERVAL 30 MINUTES"
    },
    {
      "name": "ds_slice_summary",
      "displayName": "Burst Slice Summary",
      "query": "SELECT COUNT(*) AS burst_slices FROM cmegdemos_catalog.dynamic_slicing_live_event.bronze_network_slices WHERE status = 'active' AND slice_type LIKE '%_burst'"
    },
    {
      "name": "ds_lumen_bandwidth_timeline",
      "displayName": "Lumen Field Bandwidth Timeline",
      "query": "SELECT tower_id, window_start, ROUND(avg_bandwidth_util, 2) AS avg_bandwidth_util, congestion_predicted_15min FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_congestion_features WHERE tower_id LIKE 'SEA-LF-%' ORDER BY window_start, tower_id"
    },
    {
      "name": "ds_latest_congestion",
      "displayName": "Latest Congestion Scores",
      "query": "SELECT tower_id, ROUND(avg_congestion_score, 2) AS avg_congestion_score, ROUND(avg_bandwidth_util, 2) AS avg_bandwidth_util, congestion_predicted_15min FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_congestion_features WHERE window_start = (SELECT MAX(window_start) FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_congestion_features) ORDER BY avg_congestion_score DESC"
    },
    {
      "name": "ds_event_revenue",
      "displayName": "Event Revenue Summary",
      "query": "SELECT event_name, b2b_customers_targeted, b2b_customers_accepted, ROUND(conversion_rate * 100, 1) AS conversion_rate, ROUND(immediate_monthly_upsell_usd, 0) AS immediate_monthly_upsell_usd, ROUND(projected_upsell_arr_usd, 0) AS projected_upsell_arr_usd, ROUND(arr_protected_from_churn_usd, 0) AS arr_protected_from_churn_usd, burst_slices_provisioned FROM cmegdemos_catalog.dynamic_slicing_live_event.event_revenue_summary WHERE event_name = 'USMNT vs Australia' LIMIT 1"
    },
    {
      "name": "ds_revenue_by_segment",
      "displayName": "Upsell ARR by Segment",
      "query": "SELECT customer_segment, SUM(projected_upsell_arr) AS projected_upsell_arr, SUM(high_upsell_opportunities) AS high_upsell_opportunities FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_revenue_analytics GROUP BY customer_segment ORDER BY projected_upsell_arr DESC"
    },
    {
      "name": "ds_upsell_scores",
      "displayName": "Upsell Scores by Segment",
      "query": "SELECT customer_segment, ROUND(AVG(avg_upsell_score), 4) AS avg_upsell_score, SUM(high_upsell_opportunities) AS high_upsell_opportunities, SUM(total_customers_at_risk) AS total_customers_at_risk FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_revenue_analytics GROUP BY customer_segment"
    },
    {
      "name": "ds_top_opportunities",
      "displayName": "Top B2B Upsell Opportunities",
      "query": "SELECT company_name, customer_type, customer_segment, ROUND(utilization_pct, 1) AS utilization_pct, breach_risk_level, ROUND(conversion_score, 3) AS conversion_score, ROUND(monthly_revenue_opportunity, 0) AS monthly_revenue_opportunity, tower_id FROM cmegdemos_catalog.dynamic_slicing_live_event.gold_conversion_opportunities WHERE conversion_score >= 0.65 ORDER BY conversion_score DESC, utilization_pct DESC LIMIT 100"
    }
  ]
}
